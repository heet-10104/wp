{{define "title"}}Chat Room - {{.Room}}{{end}}

{{define "body"}}

<link rel="stylesheet" href="/resources/css/style.css">

<div class="video-app">

    <!-- VIDEO -->
    <video id="videoPlayer" controls autoplay></video>

    <!-- LEFT FAB -->
    <div class="fab left" id="videoFab">🎬</div>

    <!-- VIDEO PANEL -->
    <div class="panel left-panel" id="videoPanel">
        <div class="panel-header">
            <span class="play-list">Videos</span>
        </div>

        <label class="file-btn">
            Upload
            <input type="file" id="folderInput" webkitdirectory multiple hidden>
        </label>

        <ul class="video-list"></ul>
    </div>

    <!-- RIGHT FAB -->
    <div class="fab right" id="chatFab">💬</div>

    <!-- CHAT PANEL -->
    <div class="panel chat-panel" id="chatPanel">
        <div class="panel-header">
            <span class="room-name">{{.Room}}</span>
             <div class="select-wrapper">
                    <select id="receiverSelect">
                        <option value="*">Broadcast</option>
                        {{range .Clients}}
                        <option value="{{.}}">{{.}}</option>
                        {{end}}
                    </select>
                </div>
        </div>
<br>
        <div class="chat-content">
            <div id="chatBox" class="chat-box"></div>

            <div class="chat-controls">
               
                <input type="text" id="chatInput" placeholder="Message..." />
                
            </div>
        </div>
    </div>

</div>

<script type="module" src="/resources/js/ws_client.js"></script>
<script type="module" src="/resources/js/folder_handler.js"></script>
<script type="module" src="/resources/js/chat_handler.js"></script>
<script type="module" src="/resources/js/msg_mux.js"></script>

<script>
    const videoFab = document.getElementById("videoFab");
    const chatFab = document.getElementById("chatFab");
    const videoPanel = document.getElementById("videoPanel");
    const chatPanel = document.getElementById("chatPanel");

    videoFab.onclick = () => {
        videoPanel.classList.toggle("open");
        chatPanel.classList.remove("open");
    };

    chatFab.onclick = () => {
        chatPanel.classList.toggle("open");
        videoPanel.classList.remove("open");
    };

    function closeVideoPanel() {
        videoPanel.classList.remove("open");
    }

    function closeChatPanel() {
        chatPanel.classList.remove("open");
    }

    document.addEventListener("click", (e) => {
        if (!videoPanel.contains(e.target) && !e.target.closest("#videoFab")) {
            videoPanel.classList.remove("open");
        }

        if (!chatPanel.contains(e.target) && !e.target.closest("#chatFab")) {
            chatPanel.classList.remove("open");
        }
    });

    let hideTimer;

    // all FABs
    const fabs = document.querySelectorAll(".fab");

    function showFABs() {
        fabs.forEach(fab => fab.classList.remove("hidden"));

        clearTimeout(hideTimer);

        // hide after 2.5 sec
        hideTimer = setTimeout(() => {
            fabs.forEach(fab => fab.classList.add("hidden"));
        }, 2500);
    }

    // detect mouse movement
    document.addEventListener("mousemove", showFABs);

    // show initially
    showFABs();
</script>

{{end}}